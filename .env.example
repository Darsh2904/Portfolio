# ── SERVER ──────────────────────────
PORT=5000
MONGODB_URI=mongodb://localhost:27017/darsh-portfolio
# OR MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/darsh-portfolio

# ── EMAIL (EmailJS or Nodemailer) ──
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=darshnation@gmail.com

# ── INSTANT ALERTS (optional: Telegram) ──
# Create a bot with @BotFather and get your chat ID.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── CLIENT ──────────────────────────
REACT_APP_API_URL=http://localhost:5000/api
